<mjml>
  <mj-head>
    <mj-title>EMAIL_BANNER_LABEL</mj-title>
    <mj-preview>EMAIL_BANNER_LABEL</mj-preview>
    <mj-font name="Source Sans 3" href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,400;0,600;0,700;1,400&display=swap" />
    <mj-attributes>
      <mj-all font-family="'Source Sans 3', Arial, sans-serif" />
      <mj-text font-size="15px" line-height="1.5" color="#131d24" />
    </mj-attributes>
  </mj-head>

  <mj-body background-color="#ebf1f7">

    <!-- Header -->
    <mj-section background-color="#003660" padding="20px 32px">
      <mj-column>
        <mj-text font-size="18px" font-weight="bold" color="#ffffff">
          EMAIL_GROUP_NAME
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Event banner -->
    <mj-section background-color="EMAIL_BANNER_BG" padding="14px 32px">
      <mj-column>
        <mj-text font-size="16px" font-weight="bold" color="EMAIL_BANNER_FG" padding="0">
          EMAIL_BANNER_LABEL
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Content card -->
    <mj-section background-color="#ffffff" padding="24px 32px 8px" border-radius="0">
      <mj-column>
        <mj-text padding-bottom="16px">
          Hej EMAIL_RECIPIENT_NAME,
        </mj-text>
        <mj-text padding-bottom="24px">
          EMAIL_INTRO
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Booking meta: dates + team + status -->
    <mj-section background-color="#ffffff" padding="0 32px 0">
      <mj-column border="1px solid #d7e4f0" border-radius="6px" padding="16px">
        <mj-text font-size="18px" font-weight="bold" color="#003660" padding-bottom="8px">
          EMAIL_START_DATE &ndash; EMAIL_END_DATE
        </mj-text>
        <mj-text padding-bottom="0" padding-top="0">
          <span style="display:inline-block;background:EMAIL_TEAM_BG;color:EMAIL_TEAM_FG;font-size:12px;padding:2px 8px;border-radius:4px;margin-right:6px">EMAIL_TEAM_LABEL</span><span style="display:inline-block;background:EMAIL_STATUS_BG;color:EMAIL_STATUS_FG;font-size:12px;padding:2px 8px;border-radius:4px">EMAIL_STATUS</span>
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Items list -->
    <mj-section background-color="#ffffff" padding="0 32px 0">
      <mj-column padding-top="20px">
        <mj-text font-weight="bold" color="#374b5a" padding-bottom="6px">
          EMAIL_ITEMS_HEADING
        </mj-text>
        <mj-text padding-top="0" color="#374b5a">
          EMAIL_ITEMS_HTML
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Optional sections: notes and comment thread. Each placeholder renders the full block or empty string. -->
    <mj-section background-color="#ffffff" padding="0 32px 0">
      <mj-column padding-top="0">
        <mj-text padding-top="0" padding-bottom="0" color="#608199">
          EMAIL_NOTES_BLOCK
        </mj-text>
        <mj-text padding-top="0" padding-bottom="0" color="#374b5a" font-size="14px" line-height="1.6">
          EMAIL_BOOKING_EVENTS_BLOCK
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- CTA -->
    <mj-section background-color="#ffffff" padding="24px 32px 32px">
      <mj-column>
        <mj-button background-color="EMAIL_CTA_BG" color="#ffffff" border-radius="6px" font-size="15px" font-weight="bold" padding="12px 28px" href="EMAIL_CTA_URL">
          EMAIL_CTA_LABEL
        </mj-button>
      </mj-column>
    </mj-section>

    <!-- Footer -->
    <mj-section background-color="#ebf1f7" padding="16px 32px">
      <mj-column>
        <mj-text font-size="12px" color="#608199" padding-bottom="4px">
          EMAIL_GROUP_NAME
        </mj-text>
        <mj-text font-size="12px" color="#608199" padding-top="0">
          <a href="EMAIL_UNSUBSCRIBE_URL" style="color:#608199">EMAIL_FOOTER_UNSUBSCRIBE</a>
        </mj-text>
      </mj-column>
    </mj-section>

  </mj-body>
</mjml>
